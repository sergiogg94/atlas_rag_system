# Basic settings
APP_ENV=dev
LOG_LEVEL=INFO

# Database settings
POSTGRES_USER=...
POSTGRES_PASSWORD=...
POSTGRES_DB=atlas_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE

# API keys
VOYAGE_API_KEY=...
HF_TOKEN=...
GROQ_API_KEY=...

# LLM provider settings
LLM_PROVIDER=groq

# OpenAI-compatible provider (also used for HuggingFace inference)
# OPENAI_BASE_URL=https://router.huggingface.co/v1
# OPENAI_MODEL=katanemo/Arch-Router-1.5B:hf-inference

# Groq (OpenAI-compatible API)
GROQ_MODEL=llama3-70b-8192

# API settings
API_PORT=8000
API_BASE_URL=http://localhost:${API_PORT}

# Gradio settings
GRADIO_SERVER_NAME=...
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=False